generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  DEVELOPER
  VIEWER
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  name           String
  passwordHash   String
  role           Role            @default(VIEWER)
  theme          String          @default("nocturne")
  dashboards     Dashboard[]
  activityEvents ActivityEvent[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Dashboard {
  id          String           @id @default(cuid())
  ownerId     String
  owner       User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name        String
  slug        String
  description String           @default("")
  environment String           @default("Home network")
  isDefault   Boolean          @default(false)
  revision    Int              @default(1)
  shareToken  String?          @unique
  sharedAt    DateTime?
  shareTheme  String           @default("nocturne")
  widgets     WidgetInstance[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([ownerId, slug])
  @@index([ownerId])
}

model WidgetInstance {
  id          String    @id @default(cuid())
  dashboardId String
  dashboard   Dashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)
  type        String
  title       String
  config      Json
  layout      Json
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([dashboardId])
}

model CacheEntry {
  key       String   @id
  value     Json
  expiresAt DateTime
  updatedAt DateTime @updatedAt

  @@index([expiresAt])
}

model ActivityEvent {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dashboardId String?
  action      String
  entityType  String
  entityId    String?
  message     String
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([userId, createdAt])
}
