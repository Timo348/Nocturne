{
  "name": "nocturne-homelab-dashboard",
  "version": "0.2.2",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "registry:generate": "tsx scripts/generate-widget-registry.ts",
    "predev": "pnpm registry:generate && prisma generate",
    "dev": "next dev",
    "prebuild": "pnpm registry:generate && prisma generate",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "bcryptjs": "3.0.3",
    "fast-xml-parser": "5.10.0",
    "jose": "6.2.3",
    "lucide-react": "1.24.0",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-grid-layout": "1.5.2",
    "react-resizable": "3.2.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/react-grid-layout": "1.3.6",
    "eslint": "9.39.3",
    "eslint-config-next": "16.2.10",
    "prisma": "6.19.3",
    "tsx": "4.23.0",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
